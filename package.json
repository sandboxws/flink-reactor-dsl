{
  "name": "@flink-reactor/dsl",
  "version": "0.1.8",
  "description": "React-style TSX DSL that synthesizes to Flink SQL + Kubernetes FlinkDeployment CRDs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./jsx-runtime": {
      "import": "./dist/jsx-runtime.js",
      "types": "./dist/jsx-runtime.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.js",
      "types": "./dist/browser.d.ts"
    }
  },
  "bin": {
    "flink-reactor": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src/cli/cluster/docker-compose.yml",
    "src/cli/cluster/Dockerfile.flink",
    "src/cli/cluster/data",
    "src/cli/cluster/init/00-init-databases.sh",
    "src/cli/cluster/pipelines"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.30.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/sandboxws/flink-reactor-dsl.git"
  },
  "bugs": {
    "url": "https://github.com/sandboxws/flink-reactor-dsl/issues"
  },
  "homepage": "https://github.com/sandboxws/flink-reactor-dsl#readme",
  "author": "Ahmed El.Hussaini <328866+sandboxws@users.noreply.github.com>",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build && tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:snapshots": "vitest run src/codegen/__tests__/example-snapshots.test.ts",
    "test:explain": "vitest run src/lib/sql-gateway/__tests__/explain-integration.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish && node scripts/publish-root.mjs",
    "local:publish": "bash scripts/local-publish.sh",
    "rewrite-imports": "node scripts/rewrite-imports.mjs",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "flink",
    "stream-processing",
    "tsx",
    "dsl",
    "sql",
    "kubernetes"
  ],
  "license": "BSL-1.1",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "commander": "^13.1.0",
    "dt-sql-parser": "^4.4.2",
    "effect": "^3.19.19",
    "handlebars": "^4.7.8",
    "jiti": "^2.6.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@changesets/cli": "^2.29.8",
    "@flink-reactor/ts-plugin": "workspace:*",
    "@types/node": "^22.12.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
