{
  "name": "flink-reactor",
  "version": "0.1.0",
  "description": "React-style TSX DSL that synthesizes to Flink SQL + Kubernetes FlinkDeployment CRDs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./jsx-runtime": {
      "import": "./dist/jsx-runtime.js",
      "types": "./dist/jsx-runtime.d.ts"
    }
  },
  "bin": {
    "flink-reactor": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.30.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/sandboxws/flink-reactor.git"
  },
  "bugs": {
    "url": "https://github.com/sandboxws/flink-reactor/issues"
  },
  "homepage": "https://github.com/sandboxws/flink-reactor#readme",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish && node scripts/publish-root.mjs",
    "cluster:up": "flink-reactor cluster up --seed",
    "cluster:down": "flink-reactor cluster down --volumes",
    "dev:dashboard:live": "flink-reactor cluster up --seed && pnpm --filter dashboard dev",
    "dev:dashboard:local": "FLINK_REST_URL=http://localhost:8081 pnpm --filter dashboard dev",
    "ui:embed": "pnpm --filter @flink-reactor/ui-embeddings embed",
    "ui:search": "pnpm --filter @flink-reactor/ui-embeddings search",
    "ui:benchmark": "pnpm --filter @flink-reactor/ui-embeddings benchmark",
    "docs": "pnpm -C web dev",
    "local:publish": "bash scripts/local-publish.sh",
    "rewrite-imports": "node scripts/rewrite-imports.mjs"
  },
  "keywords": [
    "flink",
    "stream-processing",
    "tsx",
    "dsl",
    "sql",
    "kubernetes"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "commander": "^13.1.0",
    "handlebars": "^4.7.8",
    "jiti": "^2.6.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@changesets/cli": "^2.29.8",
    "@flink-reactor/ts-plugin": "workspace:*",
    "@types/node": "^22.12.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
