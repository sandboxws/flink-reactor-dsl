{
  "name": "@flink-reactor/create-fr-app",
  "version": "0.1.0",
  "description": "CLI to create new apps with the FlinkReactor design system",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sandboxws/flink-reactor.git",
    "directory": "packages/create-fr-app"
  },
  "bugs": {
    "url": "https://github.com/sandboxws/flink-reactor/issues"
  },
  "homepage": "https://github.com/sandboxws/flink-reactor/tree/main/packages/create-fr-app#readme",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "create-fr-app": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts",
    "dev": "tsup src/cli.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
