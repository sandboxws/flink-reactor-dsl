{
  "name": "@flink-reactor/ts-plugin",
  "version": "0.1.0",
  "description": "TypeScript language service plugin providing JSX nesting diagnostics and context-aware completions for flink-reactor",
  "license": "BSL-1.1",
  "author": "Ahmed El.Hussaini <328866+sandboxws@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/sandboxws/flink-reactor-dsl.git",
    "directory": "packages/ts-plugin"
  },
  "bugs": {
    "url": "https://github.com/sandboxws/flink-reactor-dsl/issues"
  },
  "homepage": "https://github.com/sandboxws/flink-reactor-dsl/tree/main/packages/ts-plugin#readme",
  "keywords": [
    "typescript",
    "typescript-plugin",
    "flink",
    "jsx",
    "diagnostics",
    "flink-reactor"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
