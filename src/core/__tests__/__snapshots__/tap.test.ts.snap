exports[`Kafka tap with timestamp offset mode > generates correct startup timestamp config 1`] = `
"CREATE TEMPORARY TABLE \`_tap_orders\` (
  \`order_id\` BIGINT
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'properties.group.id' = 'fr-tap-test-orders-abc12345',
  'scan.startup.mode' = 'timestamp',
  'scan.startup.timestamp-millis' = '1705312800000'
);

SELECT * FROM \`_tap_orders\`;"
`;
