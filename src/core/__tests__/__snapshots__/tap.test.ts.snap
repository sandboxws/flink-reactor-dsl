exports[`JDBC sink tap observation SQL > generates correct observation SQL with periodic poll 1`] = `
"CREATE TEMPORARY TABLE \`_tap_users\` (
  \`id\` BIGINT,
  \`name\` STRING
) WITH (
  'connector' = 'jdbc',
  'url' = 'jdbc:postgresql://localhost:5433/db',
  'table-name' = 'users'
);

SELECT * FROM \`_tap_users\`;"
`;

exports[`Kafka sink tap observation SQL > generates correct observation SQL with latest offset 1`] = `
"CREATE TEMPORARY TABLE \`_tap_large_orders\` (
  \`order_id\` BIGINT,
  \`total\` DECIMAL(10, 2)
) WITH (
  'connector' = 'kafka',
  'topic' = 'large-orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'properties.group.id' = 'fr-tap-test-large_orders-def56789',
  'scan.startup.mode' = 'latest-offset'
);

SELECT * FROM \`_tap_large_orders\`;"
`;

