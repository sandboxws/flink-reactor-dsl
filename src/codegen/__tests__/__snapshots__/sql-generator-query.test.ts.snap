// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Query: WHERE + GROUP BY + HAVING combined > produces all clauses in correct order 1`] = `
"CREATE TABLE \`KafkaSource_0\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

CREATE TABLE \`KafkaSink_6\` WITH (
  'connector' = 'kafka',
  'topic' = 'filtered-agg',
  'format' = 'json'
);

INSERT INTO \`KafkaSink_6\`
SELECT user_id AS \`user_id\`, SUM(amount) AS \`total\` FROM \`KafkaSource_0\`
WHERE amount > 0
GROUP BY \`user_id\`
HAVING SUM(amount) > 500;
"
`;

exports[`Query: aggregation with HAVING > produces correct SQL 1`] = `
"CREATE TABLE \`KafkaSource_0\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
