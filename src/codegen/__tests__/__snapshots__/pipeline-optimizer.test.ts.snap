exports[`Source schema narrowing pass > narrows source DDL to only referenced columns 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : narrowing-pipeline
-- ====================================================================

SET 'pipeline.name' = 'narrowing-pipeline';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : orders
-- type        : kafka
-- topic       : orders
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`orders\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`product_id\` STRING,
  \`category\` STRING,
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : slim_orders
-- type        : kafka
-- topic       : slim-orders
-- format      : json
-- ====================================================================

CREATE TABLE \`slim_orders\` (
  \`user_id\` STRING,
  \`total\` DECIMAL(10, 2)
) WITH (
  'connector' = 'kafka',
  'topic' = 'slim-orders',
  'format' = 'json'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- step        : Map_1
-- type        : Map
-- input       : orders
-- output      : slim_orders
-- ====================================================================

INSERT INTO \`slim_orders\`
SELECT \`user_id\` AS \`user_id\`, \`amount\` AS \`total\` FROM \`orders\`;
"
`;

exports[`User SET precedence > does not override user-defined SET statements 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : user-set-pipeline
-- ====================================================================

SET 'pipeline.name' = 'user-set-pipeline';

SET 'table.exec.mini-batch.enabled' = 'false';

SET 'table.exec.mini-batch.allow-latency' = '10 s';

SET 'table.exec.mini-batch.size' = '1000';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : orders
-- type        : kafka
-- topic       : orders
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`orders\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`product_id\` STRING,
  \`category\` STRING,
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : totals
-- type        : kafka
-- topic       : totals
-- format      : json
-- ====================================================================

CREATE TABLE \`totals\` (
  \`user_id\` STRING,
  \`total_amount\` DECIMAL(10, 2),
  PRIMARY KEY (\`user_id\`) NOT ENFORCED
) WITH (
  'connector' = 'upsert-kafka',
  'topic' = 'totals',
  'key.format' = 'json',
  'value.format' = 'json'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- step        : Aggregate_1
-- type        : Aggregate
-- input       : orders
-- output      : totals
-- group-by    : user_id
-- ====================================================================

INSERT INTO \`totals\`
SELECT \`user_id\`, SUM(\`amount\`) AS \`total_amount\` FROM \`orders\` GROUP BY \`user_id\`;
"
`;
