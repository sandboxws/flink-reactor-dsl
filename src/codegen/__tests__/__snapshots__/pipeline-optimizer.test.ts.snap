// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Dead branch elimination pass > eliminates Route branches with statically false conditions 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : dead-branch-pipeline
-- ====================================================================

SET 'pipeline.name' = 'dead-branch-pipeline';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : events
-- type        : kafka
-- topic       : events
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`events\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`product_id\` STRING,
  \`category\` STRING,
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'events',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : live_branch
-- type        : kafka
-- topic       : live-branch
-- format      : json
-- ====================================================================

CREATE TABLE \`live_branch\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`product_id\` STRING,
  \`category\` STRING,
  \`event_time\` TIMESTAMP(3)
) WITH (
  'connector' = 'kafka',
  'topic' = 'live-branch',
  'format' = 'json'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : default_branch
-- type        : kafka
-- topic       : default-branch
-- format      : json
-- ====================================================================

CREATE TABLE \`default_branch\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`product_id\` STRING,
  \`category\` STRING,
  \`event_time\` TIMESTAMP(3)
) WITH (
  'connector' = 'kafka',
  'topic' = 'default-branch',
  'format' = 'json'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : events
-- output      : live_branch
-- ====================================================================

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : events
-- output      : default_branch
-- ====================================================================

EXECUTE STATEMENT SET BEGIN
INSERT INTO \`live_branch\`
SELECT * FROM \`events\`
WHERE \`amount\` > 100;
INSERT INTO \`default_branch\`
SELECT * FROM \`events\`;
END;
"
`;

exports[`Deterministic snapshot tests > optimizer produces deterministic output for aggregate pipeline 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : deterministic-pipeline
-- ====================================================================

SET 'pipeline.name' = 'deterministic-pipeline';

SET 'table.exec.mini-batch.enabled' = 'true';

SET 'table.exec.mini-batch.allow-latency' = '5 s';

SET 'table.exec.mini-batch.size' = '1000';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : orders
-- type        : kafka
-- topic       : orders
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`orders\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`product_id\` STRING,
  \`category\` STRING,
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : user_totals
-- type        : kafka
-- topic       : user-totals
-- format      : json
-- ====================================================================

CREATE TABLE \`user_totals\` (
  \`user_id\` STRING,
  \`total_amount\` DECIMAL(10, 2),
  \`order_count\` BIGINT,
  PRIMARY KEY (\`user_id\`) NOT ENFORCED
) WITH (
  'connector' = 'upsert-kafka',
  'topic' = 'user-totals',
  'key.format' = 'json',
  'value.format' = 'json'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- step        : Aggregate_1
-- type        : Aggregate
-- input       : orders
-- output      : user_totals
-- group-by    : user_id
-- ====================================================================

INSERT INTO \`user_totals\`
SELECT \`user_id\`, SUM(\`amount\`) AS \`total_amount\`, COUNT(*) AS \`order_count\` FROM \`orders\` GROUP BY \`user_id\`;
"
`;

exports[`Deterministic snapshot tests > optimizer produces deterministic output for join pipeline 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : deterministic-join-pipeline
-- ====================================================================

SET 'pipeline.name' = 'deterministic-join-pipeline';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : orders
-- type        : kafka
-- topic       : orders
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`orders\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`product_id\` STRING,
  \`category\` STRING,
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : users
-- type        : kafka
-- topic       : users
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`users\` (
  \`user_id\` STRING,
  \`name\` STRING,
  \`email\` STRING
) WITH (
  'connector' = 'kafka',
  'topic' = 'users',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : enriched
-- type        : kafka
-- topic       : enriched
-- format      : json
-- ====================================================================

CREATE TABLE \`enriched\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`product_id\` STRING,
  \`category\` STRING,
  \`event_time\` TIMESTAMP(3)
) WITH (
  'connector' = 'kafka',
  'topic' = 'enriched',
  'format' = 'json'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : orders
-- output      : enriched
-- ====================================================================

INSERT INTO \`enriched\`
SELECT /*+ BROADCAST(\`users\`) */ * FROM \`orders\` INNER JOIN \`users\` ON \`orders\`.\`user_id\` = \`users\`.\`user_id\`;
"
`;

exports[`Deterministic snapshot tests > optimizer produces deterministic output for route pipeline 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : deterministic-route-pipeline
-- ====================================================================

SET 'pipeline.name' = 'deterministic-route-pipeline';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : events
-- type        : kafka
-- topic       : events
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`events\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`product_id\` STRING,
  \`category\` STRING,
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'events',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : high_value
-- type        : kafka
-- topic       : high-value
-- format      : json
-- ====================================================================

CREATE TABLE \`high_value\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`product_id\` STRING,
  \`category\` STRING,
  \`event_time\` TIMESTAMP(3)
) WITH (
  'connector' = 'kafka',
  'topic' = 'high-value',
  'format' = 'json'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : other
-- type        : kafka
-- topic       : other
-- format      : json
-- ====================================================================

CREATE TABLE \`other\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`product_id\` STRING,
  \`category\` STRING,
  \`event_time\` TIMESTAMP(3)
) WITH (
  'connector' = 'kafka',
  'topic' = 'other',
  'format' = 'json'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : events
-- output      : high_value
-- ====================================================================

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : events
-- output      : other
-- ====================================================================

EXECUTE STATEMENT SET BEGIN
INSERT INTO \`high_value\`
SELECT * FROM \`events\`
WHERE \`amount\` > 1000;
INSERT INTO \`other\`
SELECT * FROM \`events\`;
END;
"
`;

exports[`SET injection pass > injects mini-batch SET statements when Aggregate detected 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : agg-pipeline
-- ====================================================================

SET 'pipeline.name' = 'agg-pipeline';

SET 'table.exec.mini-batch.enabled' = 'true';

SET 'table.exec.mini-batch.allow-latency' = '5 s';

SET 'table.exec.mini-batch.size' = '1000';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : orders
-- type        : kafka
-- topic       : orders
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`orders\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`product_id\` STRING,
  \`category\` STRING,
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : user_totals
-- type        : kafka
-- topic       : user-totals
-- format      : json
-- ====================================================================

CREATE TABLE \`user_totals\` (
  \`user_id\` STRING,
  \`total_amount\` DECIMAL(10, 2),
  \`order_count\` BIGINT,
  PRIMARY KEY (\`user_id\`) NOT ENFORCED
) WITH (
  'connector' = 'upsert-kafka',
  'topic' = 'user-totals',
  'key.format' = 'json',
  'value.format' = 'json'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- step        : Aggregate_1
-- type        : Aggregate
-- input       : orders
-- output      : user_totals
-- group-by    : user_id
-- ====================================================================

INSERT INTO \`user_totals\`
SELECT \`user_id\`, SUM(\`amount\`) AS \`total_amount\`, COUNT(*) AS \`order_count\` FROM \`orders\` GROUP BY \`user_id\`;
"
`;

