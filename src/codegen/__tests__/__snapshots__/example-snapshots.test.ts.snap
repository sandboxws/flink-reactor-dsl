INSERT INTO \`typed_sensor_data\`
SELECT \`sensor_id\`, TRY_CAST(\`temperature\` AS DOUBLE) AS \`temperature\`, TRY_CAST(\`humidity\` AS DOUBLE) AS \`humidity\`, TRY_CAST(\`reading_time\` AS TIMESTAMP(3)) AS \`reading_time\` FROM \`raw_sensor_data\`;
