`;

exports[`Example SQL Snapshots > 36-coalesce-defaults 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : fill-profile-defaults
-- parallelism : 4
-- ====================================================================

SET 'pipeline.name' = 'fill-profile-defaults';

SET 'parallelism.default' = '4';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : user_profiles
-- type        : kafka
-- topic       : user_profiles
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`user_profiles\` (
  \`user_id\` STRING,
  \`display_name\` STRING,
  \`locale\` STRING,
  \`timezone\` STRING,
  \`updated_at\` TIMESTAMP(3)
) WITH (
  'connector' = 'kafka',
  'topic' = 'user_profiles',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : enriched_profiles
-- type        : kafka
-- topic       : enriched_profiles
-- format      : json
-- ====================================================================

CREATE TABLE \`enriched_profiles\` (
  \`user_id\` STRING,
  \`display_name\` STRING,
  \`locale\` STRING,
  \`timezone\` STRING,
  \`updated_at\` TIMESTAMP(3)
) WITH (
  'connector' = 'kafka',
  'topic' = 'enriched_profiles',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- step        : Coalesce_1
-- type        : Coalesce
-- input       : user_profiles
-- output      : enriched_profiles
-- ====================================================================

INSERT INTO \`enriched_profiles\`
SELECT \`user_id\`, COALESCE(\`display_name\`, user_id) AS \`display_name\`, COALESCE(\`locale\`, 'en-US') AS \`locale\`, COALESCE(\`timezone\`, 'UTC') AS \`timezone\`, \`updated_at\` FROM \`user_profiles\`;
"
`;

exports[`Example SQL Snapshots > 37-add-computed-field 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : enrich-orders
-- parallelism : 8
-- ====================================================================

SET 'pipeline.name' = 'enrich-orders';

SET 'parallelism.default' = '8';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : orders
-- type        : kafka
-- topic       : orders
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`orders\` (
  \`order_id\` STRING,
  \`product_id\` STRING,
  \`quantity\` INT,
  \`unit_price\` DECIMAL(10, 2),
  \`order_time\` TIMESTAMP(3)
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : enriched_orders
-- type        : kafka
-- topic       : enriched_orders
-- format      : json
-- ====================================================================

CREATE TABLE \`enriched_orders\` (
  \`order_id\` STRING,
  \`product_id\` STRING,
  \`quantity\` INT,
  \`unit_price\` DECIMAL(10, 2),
  \`order_time\` TIMESTAMP(3),
  \`total_price\` DECIMAL(10, 2),
  \`is_high_value\` BOOLEAN
) WITH (
  'connector' = 'kafka',
  'topic' = 'enriched_orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- step        : AddField_1
-- type        : AddField
-- input       : orders
-- output      : enriched_orders
-- ====================================================================

INSERT INTO \`enriched_orders\`
SELECT *, quantity * unit_price AS \`total_price\`, quantity * unit_price > 500 AS \`is_high_value\` FROM \`orders\`;
"
`;

exports[`Example SQL Snapshots > 38-dedup-aggregate 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : hourly-user-events
-- parallelism : 16
-- ====================================================================

SET 'pipeline.name' = 'hourly-user-events';

SET 'parallelism.default' = '16';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : raw_events
-- type        : kafka
-- topic       : raw_events
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`raw_events\` (
  \`event_id\` STRING,
  \`user_id\` STRING,
  \`event_type\` STRING,
  \`event_data\` STRING,
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS event_time - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'raw_events',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : hourly_user_events
-- type        : kafka
-- topic       : hourly_user_events
-- format      : json
-- ====================================================================

CREATE TABLE \`hourly_user_events\` (
  \`user_id\` STRING,
  \`event_type\` STRING,
  \`event_count\` BIGINT,
  \`window_start\` TIMESTAMP(3),
  \`window_end\` TIMESTAMP(3)
) WITH (
  'connector' = 'kafka',
  'topic' = 'hourly_user_events',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- step        : Deduplicate_1
-- type        : Deduplicate
-- input       : raw_events
-- output      : hourly_user_events
-- ====================================================================

INSERT INTO \`hourly_user_events\`
WITH \`_windowed_input\` AS (
SELECT *, ROW_NUMBER() OVER (PARTITION BY \`event_id\` ORDER BY \`event_time\` ASC) AS rownum
FROM \`raw_events\`
QUALIFY rownum = 1
)
SELECT \`user_id\`, \`event_type\`, COUNT(*) AS \`event_count\`, window_start, window_end FROM TABLE(
  TUMBLE(TABLE \`_windowed_input\`, DESCRIPTOR(\`event_time\`), INTERVAL '1' HOUR)
) GROUP BY \`user_id\`, \`event_type\`, window_start, window_end;
"
`;
