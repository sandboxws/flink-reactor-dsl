  \`event_id\` STRING,
  \`user_id\` STRING,
  \`event_type\` STRING,
  \`region\` STRING,
  \`event_time\` TIMESTAMP(3)
) WITH (
  'connector' = 'kafka',
  'topic' = 'events_global',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka-us:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- step        : Union_2
-- type        : Union
-- input       : events_us
-- output      : events_global
-- ====================================================================

INSERT INTO \`events_global\`
SELECT * FROM \`events_us\`
UNION ALL
SELECT * FROM \`events_eu\`;
"
`;

