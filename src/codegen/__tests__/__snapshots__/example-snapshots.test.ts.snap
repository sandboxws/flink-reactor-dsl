  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka-us:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : events_eu
-- type        : kafka
-- topic       : events_eu
-- format      : json
-- bootstrap   : kafka-eu:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`events_eu\` (
  \`event_id\` STRING,
  \`user_id\` STRING,
  \`event_type\` STRING,
  \`region\` STRING,
  \`event_time\` TIMESTAMP(3)
) WITH (
  'connector' = 'kafka',
  'topic' = 'events_eu',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka-eu:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
