-- name        : cast-sensor-readings
-- parallelism : 4
-- ====================================================================

SET 'pipeline.name' = 'cast-sensor-readings';

SET 'parallelism.default' = '4';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : raw_sensor_data
-- type        : kafka
-- topic       : raw_sensor_data
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`raw_sensor_data\` (
  \`sensor_id\` STRING,
  \`temperature\` STRING,
  \`humidity\` STRING,
  \`reading_time\` STRING
) WITH (
  'connector' = 'kafka',
  'topic' = 'raw_sensor_data',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : typed_sensor_data
-- type        : kafka
-- topic       : typed_sensor_data
-- format      : json
-- ====================================================================

CREATE TABLE \`typed_sensor_data\` (
  \`sensor_id\` STRING,
  \`temperature\` DOUBLE,
  \`humidity\` DOUBLE,
  \`reading_time\` TIMESTAMP(3)
) WITH (
  'connector' = 'kafka',
  'topic' = 'typed_sensor_data',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

