"SET 'pipeline.name' = 'forward-chained';

CREATE TABLE \`products\` (
  \`id\` INT,
  \`name\` STRING,
  \`price\` DOUBLE,
  \`internal_id\` STRING,
  \`debug_flag\` BOOLEAN,
