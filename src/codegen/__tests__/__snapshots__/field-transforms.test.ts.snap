  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : output
-- type        : kafka
-- topic       : output
-- format      : json
-- ====================================================================

CREATE TABLE \`output\` (
  \`product_id\` INT,
  \`name\` STRING,
  \`price\` DOUBLE,
  \`internal_id\` STRING,
  \`debug_flag\` BOOLEAN
) WITH (
  'connector' = 'kafka',
  'topic' = 'output',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- step        : Rename_1
-- type        : Rename
-- input       : products
-- output      : output
-- ====================================================================

INSERT INTO \`output\`
SELECT \`id\` AS \`product_id\`, \`name\`, \`price\`, \`internal_id\`, \`debug_flag\` FROM \`products\`;
"
`;

exports[`chained field transforms > Drop → Rename → Cast → AddField produces nested SQL 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : chained-pipeline
-- ====================================================================

SET 'pipeline.name' = 'chained-pipeline';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : products
-- type        : kafka
-- topic       : products
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`products\` (
  \`id\` INT,
  \`name\` STRING,
  \`price\` DOUBLE,
  \`internal_id\` STRING,
  \`debug_flag\` BOOLEAN,
  PRIMARY KEY (\`id\`) NOT ENFORCED
) WITH (
  'connector' = 'kafka',
  'topic' = 'products',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : output
-- type        : kafka
-- topic       : output
-- format      : json
-- ====================================================================

CREATE TABLE \`output\` (
  \`id\` BIGINT,
  \`product_name\` STRING,
  \`price\` DOUBLE,
  \`internal_id\` STRING,
  \`discounted\` DOUBLE
) WITH (
  'connector' = 'kafka',
  'topic' = 'output',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- transforms  : Drop → Rename → Cast → AddField
-- input       : products
-- output      : output
-- ====================================================================

INSERT INTO \`output\`
SELECT *, price * 0.9 AS \`discounted\` FROM (
SELECT CAST(\`id\` AS BIGINT) AS \`id\`, \`product_name\`, \`price\`, \`internal_id\` FROM (
SELECT \`id\`, \`name\` AS \`product_name\`, \`price\`, \`internal_id\` FROM (
SELECT \`id\`, \`name\`, \`price\`, \`internal_id\` FROM \`products\`
)
)
);
"
`;

exports[`chained field transforms > chained field transforms in forward-reading JSX pattern 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : forward-chained
-- ====================================================================

SET 'pipeline.name' = 'forward-chained';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : products
-- type        : kafka
-- topic       : products
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
