  \`price\` DOUBLE,
  \`internal_id\` STRING,
  \`discounted\` STRING
) WITH (
  'connector' = 'kafka',
  'topic' = 'output',
  'format' = 'json'
);

INSERT INTO \`output\`
SELECT *, price * 0.9 AS \`discounted\` FROM (
SELECT CAST(\`id\` AS BIGINT) AS \`id\`, \`product_name\`, \`price\`, \`internal_id\` FROM (
SELECT \`id\`, \`name\` AS \`product_name\`, \`price\`, \`internal_id\` FROM (
SELECT \`id\`, \`name\`, \`price\`, \`internal_id\` FROM \`products\`
)
)
);
"
`;

