// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`AddField (reverse-nesting) > generates SELECT *, expr AS alias 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : addfield-pipeline
-- ====================================================================

SET 'pipeline.name' = 'addfield-pipeline';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : products
-- type        : kafka
-- topic       : products
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`products\` (
  \`id\` INT,
  \`name\` STRING,
  \`price\` DOUBLE,
  \`internal_id\` STRING,
  \`debug_flag\` BOOLEAN,
  PRIMARY KEY (\`id\`) NOT ENFORCED
) WITH (
  'connector' = 'kafka',
  'topic' = 'products',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : output
-- type        : kafka
-- topic       : output
-- format      : json
-- ====================================================================

CREATE TABLE \`output\` (
  \`id\` INT,
  \`name\` STRING,
  \`price\` DOUBLE,
  \`internal_id\` STRING,
  \`debug_flag\` BOOLEAN,
  \`total\` DOUBLE,
  \`processed_at\` STRING
) WITH (
  'connector' = 'kafka',
  'topic' = 'output',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- step        : AddField_1
-- type        : AddField
-- input       : products
-- output      : output
-- ====================================================================

INSERT INTO \`output\`
SELECT *, price * 2 AS \`total\`, CURRENT_TIMESTAMP AS \`processed_at\` FROM \`products\`;
"
`;

exports[`Cast (reverse-nesting) > generates CAST for targeted fields 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : cast-pipeline
-- ====================================================================

SET 'pipeline.name' = 'cast-pipeline';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : products
-- type        : kafka
-- topic       : products
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`products\` (
  \`id\` INT,
  \`name\` STRING,
  \`price\` DOUBLE,
  \`internal_id\` STRING,
  \`debug_flag\` BOOLEAN,
  PRIMARY KEY (\`id\`) NOT ENFORCED
) WITH (
  'connector' = 'kafka',
  'topic' = 'products',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : output
-- type        : kafka
-- topic       : output
-- format      : json
-- ====================================================================

CREATE TABLE \`output\` (
  \`id\` BIGINT,
  \`name\` STRING,
  \`price\` DECIMAL(10, 2),
  \`internal_id\` STRING,
  \`debug_flag\` BOOLEAN
) WITH (
  'connector' = 'kafka',
  'topic' = 'output',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- step        : Cast_1
-- type        : Cast
-- input       : products
-- output      : output
-- ====================================================================

INSERT INTO \`output\`
SELECT CAST(\`id\` AS BIGINT) AS \`id\`, \`name\`, CAST(\`price\` AS DECIMAL(10, 2)) AS \`price\`, \`internal_id\`, \`debug_flag\` FROM \`products\`;
"
`;

