  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

CREATE TABLE \`output\` (
  \`product_id\` INT,
  \`name\` STRING,
  \`price\` DOUBLE,
  \`internal_id\` STRING,
  \`debug_flag\` BOOLEAN
) WITH (
  'connector' = 'kafka',
  'topic' = 'output',
  'format' = 'json'
);

INSERT INTO \`output\`
