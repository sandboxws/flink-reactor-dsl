exports[`field transforms (forward-reading JSX) > Rename works as a sibling between source and sink 1`] = `
"SET 'pipeline.name' = 'forward-rename';

CREATE TABLE \`products\` (
  \`id\` INT,
  \`name\` STRING,
  \`price\` DOUBLE,
  \`internal_id\` STRING,
  \`debug_flag\` BOOLEAN,
  PRIMARY KEY (\`id\`) NOT ENFORCED
) WITH (
  'connector' = 'kafka',
  'topic' = 'products',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

CREATE TABLE \`output\` (
  \`product_id\` INT,
  \`product_name\` STRING,
  \`price\` DOUBLE,
  \`internal_id\` STRING,
  \`debug_flag\` BOOLEAN
