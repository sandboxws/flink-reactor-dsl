  \`price\` DOUBLE,
  \`internal_id\` STRING,
  \`debug_flag\` BOOLEAN,
  PRIMARY KEY (\`id\`) NOT ENFORCED
) WITH (
  'connector' = 'kafka',
  'topic' = 'products',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : output
-- type        : kafka
-- topic       : output
-- format      : json
-- ====================================================================

CREATE TABLE \`output\` (
  \`id\` BIGINT,
  \`product_name\` STRING,
  \`price\` DOUBLE,
  \`internal_id\` STRING,
  \`discounted\` DOUBLE
) WITH (
  'connector' = 'kafka',
  'topic' = 'output',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- transforms  : Drop → Rename → Cast → AddField
-- input       : products
-- output      : output
-- ====================================================================

INSERT INTO \`output\`
SELECT *, price * 0.9 AS \`discounted\` FROM (
SELECT CAST(\`id\` AS BIGINT) AS \`id\`, \`product_name\`, \`price\`, \`internal_id\` FROM (
SELECT \`id\`, \`name\` AS \`product_name\`, \`price\`, \`internal_id\` FROM (
SELECT \`id\`, \`name\`, \`price\`, \`internal_id\` FROM \`products\`
)
)
);
"
`;

exports[`field transforms (forward-reading JSX) > Drop works as a sibling between source and sink 1`] = `
