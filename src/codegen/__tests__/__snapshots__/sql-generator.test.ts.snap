exports[`9.3: MatchRecognize generates MATCH_RECOGNIZE clause > produces MATCH_RECOGNIZE with PARTITION BY, ORDER BY, MEASURES, PATTERN, DEFINE 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : cep-pipeline
-- ====================================================================

SET 'pipeline.name' = 'cep-pipeline';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : transactions
-- type        : kafka
-- topic       : transactions
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`transactions\` (
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`event_type\` STRING,
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'transactions',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : fraud_alerts
-- type        : kafka
-- topic       : fraud-alerts
-- format      : json
-- ====================================================================

CREATE TABLE \`fraud_alerts\` (
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`event_type\` STRING,
  \`event_time\` TIMESTAMP(3)
) WITH (
  'connector' = 'kafka',
  'topic' = 'fraud-alerts',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : transactions
-- output      : fraud_alerts
-- ====================================================================

INSERT INTO \`fraud_alerts\`
SELECT *
FROM \`transactions\`
MATCH_RECOGNIZE (
  PARTITION BY \`user_id\`
  ORDER BY \`event_time\`
  MEASURES
    A.\`event_time\` AS \`start_time\`,
    C.\`event_time\` AS \`end_time\`,
    SUM(B.\`amount\`) AS \`total_amount\`
  AFTER MATCH SKIP PAST LAST ROW
  PATTERN (A B+ C)
  DEFINE
    A AS A.\`event_type\` = 'login',
    B AS B.\`amount\` > 1000,
    C AS C.\`event_type\` = 'withdrawal'
);
"
`;

exports[`LateralJoin produces LATERAL TABLE > generates cross join lateral table SQL 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : lateral-join-pipeline
-- ====================================================================

SET 'pipeline.name' = 'lateral-join-pipeline';

-- ====================================================================
-- FUNCTION
-- --------------------------------------------------------------------
-- name        : parse_address
-- class       : com.mycompany.fns.AddressParser
-- language    : java
-- ====================================================================

CREATE FUNCTION \`parse_address\` AS 'com.mycompany.fns.AddressParser';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : orders
-- type        : kafka
-- topic       : orders
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`orders\` (
  \`order_id\` BIGINT,
  \`shipping_address\` STRING,
  \`amount\` DECIMAL(10, 2)
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : enriched_orders
-- type        : kafka
-- topic       : enriched-orders
-- format      : json
-- ====================================================================

CREATE TABLE \`enriched_orders\` (
  \`order_id\` BIGINT,
  \`shipping_address\` STRING,
  \`amount\` DECIMAL(10, 2)
) WITH (
  'connector' = 'kafka',
  'topic' = 'enriched-orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : orders
-- output      : enriched_orders
-- ====================================================================

INSERT INTO \`enriched_orders\`
SELECT \`orders\`.*, T.\`street\`, T.\`city\`, T.\`zip\` FROM \`orders\` JOIN LATERAL TABLE(parse_address(shipping_address)) AS T(\`street\`, \`city\`, \`zip\`);
"
`;

exports[`LateralJoin produces LATERAL TABLE > generates left join lateral table SQL 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : left-lateral-pipeline
-- ====================================================================

SET 'pipeline.name' = 'left-lateral-pipeline';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : documents
-- type        : kafka
-- topic       : documents
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`documents\` (
  \`doc_id\` BIGINT,
  \`content\` STRING
) WITH (
  'connector' = 'kafka',
  'topic' = 'documents',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : entities
-- type        : kafka
-- topic       : entities
-- format      : json
-- ====================================================================

CREATE TABLE \`entities\` (
  \`doc_id\` BIGINT,
  \`content\` STRING
) WITH (
  'connector' = 'kafka',
  'topic' = 'entities',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : documents
-- output      : entities
-- ====================================================================

INSERT INTO \`entities\`
SELECT \`documents\`.*, T.\`entity\`, T.\`entity_type\` FROM \`documents\` LEFT JOIN LATERAL TABLE(extract_entities(content)) AS T(\`entity\`, \`entity_type\`);
"
`;

exports[`QUALIFY: Deduplicate version-aware codegen > uses QUALIFY on Flink 2.0 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : dedup-pipeline
-- ====================================================================

SET 'pipeline.name' = 'dedup-pipeline';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : events
-- type        : kafka
-- topic       : events
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`events\` (
  \`event_id\` BIGINT,
  \`user_id\` STRING,
  \`event_type\` STRING,
  \`event_time\` TIMESTAMP(3),
  \`payload\` STRING,
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'events',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : deduped_events
-- type        : kafka
-- topic       : deduped-events
-- format      : json
-- ====================================================================

CREATE TABLE \`deduped_events\` (
  \`event_id\` BIGINT,
  \`user_id\` STRING,
  \`event_type\` STRING,
  \`event_time\` TIMESTAMP(3),
  \`payload\` STRING,
  \`rownum\` BIGINT
) WITH (
  'connector' = 'kafka',
  'topic' = 'deduped-events',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- step        : Deduplicate_1
-- type        : Deduplicate
-- input       : events
-- output      : deduped_events
-- ====================================================================

INSERT INTO \`deduped_events\`
SELECT *, ROW_NUMBER() OVER (PARTITION BY \`event_id\` ORDER BY \`event_time\` ASC) AS rownum
FROM \`events\`
QUALIFY rownum = 1;
"
`;

