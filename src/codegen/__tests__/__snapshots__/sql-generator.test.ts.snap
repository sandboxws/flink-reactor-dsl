exports[`6.9: LookupJoin with async config > produces lookup join with proc_time and FOR SYSTEM_TIME AS OF 1`] = `
"CREATE TABLE \`KafkaSource_0\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

CREATE TABLE \`KafkaSink_2\` WITH (
  'connector' = 'kafka',
  'topic' = 'enriched-orders',
  'format' = 'json'
);

INSERT INTO \`KafkaSink_2\`
SELECT * FROM \`KafkaSource_0\` LEFT JOIN \`dim_users\` FOR SYSTEM_TIME AS OF \`KafkaSource_0\`.proc_time ON \`KafkaSource_0\`.\`user_id\` = \`dim_users\`.\`user_id\`;
"
`;

exports[`6.10: IntervalJoin with time bounds > produces BETWEEN ... AND ... time predicates 1`] = `
"CREATE TABLE \`KafkaSource_0\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

CREATE TABLE \`KafkaSource_1\` (
  \`order_id\` BIGINT,
  \`shipped_time\` TIMESTAMP(3),
  \`carrier\` STRING,
  WATERMARK FOR \`shipped_time\` AS \`shipped_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'shipments',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

CREATE TABLE \`KafkaSink_3\` WITH (
  'connector' = 'kafka',
  'topic' = 'order-shipments',
  'format' = 'json'
);

INSERT INTO \`KafkaSink_3\`
SELECT * FROM \`KafkaSource_0\` JOIN \`KafkaSource_1\` ON \`KafkaSource_0\`.\`order_id\` = \`KafkaSource_1\`.\`order_id\` AND \`KafkaSource_0\`.event_time BETWEEN \`KafkaSource_1\`.event_time AND \`KafkaSource_1\`.event_time + INTERVAL '7' DAY;
"
`;

