-- format      : json
-- ====================================================================

CREATE TABLE \`good_events\` WITH (
  'connector' = 'kafka',
  'topic' = 'good-events',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : bad_events
-- type        : kafka
-- topic       : bad-events
-- format      : json
