"
`;

exports[`9.3: MatchRecognize generates MATCH_RECOGNIZE clause > produces MATCH_RECOGNIZE with PARTITION BY, ORDER BY, MEASURES, PATTERN, DEFINE 1`] = `
"CREATE TABLE \`KafkaSource_0\` (
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`event_type\` STRING,
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'transactions',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

CREATE TABLE \`KafkaSink_2\` WITH (
  'connector' = 'kafka',
  'topic' = 'fraud-alerts',
  'format' = 'json'
);

INSERT INTO \`KafkaSink_2\`
SELECT *
FROM \`KafkaSource_0\`
MATCH_RECOGNIZE (
  PARTITION BY \`user_id\`
  ORDER BY \`event_time\`
  MEASURES
    A.\`event_time\` AS \`start_time\`,
    C.\`event_time\` AS \`end_time\`,
    SUM(B.\`amount\`) AS \`total_amount\`
  AFTER MATCH SKIP PAST LAST ROW
  PATTERN (A B+ C)
  DEFINE
    A AS A.\`event_type\` = 'login',
    B AS B.\`amount\` > 1000,
    C AS C.\`event_type\` = 'withdrawal'
);
"
`;

exports[`LateralJoin produces LATERAL TABLE > generates cross join lateral table SQL 1`] = `
"CREATE FUNCTION \`parse_address\` AS 'com.mycompany.fns.AddressParser';

CREATE TABLE \`KafkaSource_0\` (
  \`order_id\` BIGINT,
  \`shipping_address\` STRING,
  \`amount\` DECIMAL(10, 2)
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

CREATE TABLE \`KafkaSink_2\` WITH (
  'connector' = 'kafka',
  'topic' = 'enriched-orders',
  'format' = 'json'
);

INSERT INTO \`KafkaSink_2\`
SELECT \`KafkaSource_0\`.*, T.\`street\`, T.\`city\`, T.\`zip\` FROM \`KafkaSource_0\` JOIN LATERAL TABLE(parse_address(shipping_address)) AS T(\`street\`, \`city\`, \`zip\`);
"
`;

exports[`LateralJoin produces LATERAL TABLE > generates left join lateral table SQL 1`] = `
"CREATE TABLE \`KafkaSource_0\` (
  \`doc_id\` BIGINT,
  \`content\` STRING
) WITH (
  'connector' = 'kafka',
  'topic' = 'documents',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

CREATE TABLE \`KafkaSink_2\` WITH (
  'connector' = 'kafka',
  'topic' = 'entities',
  'format' = 'json'
);

INSERT INTO \`KafkaSink_2\`
SELECT \`KafkaSource_0\`.*, T.\`entity\`, T.\`entity_type\` FROM \`KafkaSource_0\` LEFT JOIN LATERAL TABLE(extract_entities(content)) AS T(\`entity\`, \`entity_type\`);
"
`;

exports[`SideOutput produces STATEMENT SET with main + side INSERTs > generates WHERE NOT for main path and WHERE for side path with metadata 1`] = `
"CREATE TABLE \`KafkaSource_0\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

CREATE TABLE \`KafkaSink_4\` WITH (
  'connector' = 'kafka',
  'topic' = 'processed-orders',
  'format' = 'json'
);

CREATE TABLE \`KafkaSink_1\` WITH (
  'connector' = 'kafka',
  'topic' = 'order-errors',
  'format' = 'json'
);

EXECUTE STATEMENT SET BEGIN
INSERT INTO \`KafkaSink_4\`
SELECT * FROM \`KafkaSource_0\` WHERE NOT (amount < 0 OR user_id IS NULL);
INSERT INTO \`KafkaSink_1\`
SELECT *, CURRENT_TIMESTAMP AS \`_side_ts\`, 'invalid-order' AS \`_side_tag\` FROM \`KafkaSource_0\` WHERE (amount < 0 OR user_id IS NULL);
END;
"
`;

