END;
"
`;

exports[`Validate produces STATEMENT SET with valid + reject INSERTs > generates full validation SQL with notNull, range, and expression rules 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : validate-pipeline
-- ====================================================================

SET 'pipeline.name' = 'validate-pipeline';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : raw_orders
-- type        : kafka
-- topic       : raw-orders
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`raw_orders\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`email\` STRING
) WITH (
  'connector' = 'kafka',
  'topic' = 'raw-orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : valid_orders
-- type        : kafka
-- topic       : valid-orders
-- format      : json
-- ====================================================================

CREATE TABLE \`valid_orders\` WITH (
  'connector' = 'kafka',
  'topic' = 'valid-orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : invalid_orders
-- type        : kafka
-- topic       : invalid-orders
-- format      : json
-- ====================================================================

CREATE TABLE \`invalid_orders\` WITH (
  'connector' = 'kafka',
  'topic' = 'invalid-orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : raw_orders
-- output      : valid_orders
-- ====================================================================

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : raw_orders
-- output      : invalid_orders
-- ====================================================================

EXECUTE STATEMENT SET BEGIN
INSERT INTO \`valid_orders\`
SELECT * FROM \`raw_orders\`
WHERE \`order_id\` IS NOT NULL
    AND \`user_id\` IS NOT NULL
    AND \`amount\` IS NOT NULL
    AND \`amount\` >= 0 AND \`amount\` <= 1000000
    AND email LIKE '%@%.%';
INSERT INTO \`invalid_orders\`
SELECT *,
    CASE
      WHEN \`order_id\` IS NULL THEN 'notNull:order_id'
      WHEN \`user_id\` IS NULL THEN 'notNull:user_id'
      WHEN \`amount\` IS NULL THEN 'notNull:amount'
      WHEN \`amount\` < 0 OR \`amount\` > 1000000 THEN 'range:amount[0,1000000]'
      WHEN NOT (email LIKE '%@%.%') THEN 'expression:valid_email'
    END AS \`_validation_error\`,
    CURRENT_TIMESTAMP AS \`_validated_at\`
FROM \`raw_orders\`
WHERE NOT (
    \`order_id\` IS NOT NULL
    AND \`user_id\` IS NOT NULL
    AND \`amount\` IS NOT NULL
    AND \`amount\` >= 0 AND \`amount\` <= 1000000
    AND email LIKE '%@%.%'
);
END;
"
`;

exports[`Validate produces STATEMENT SET with valid + reject INSERTs > generates notNull-only validation 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : notnull-pipeline
-- ====================================================================

SET 'pipeline.name' = 'notnull-pipeline';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : events
-- type        : kafka
-- topic       : events
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`events\` (
  \`event_id\` BIGINT,
  \`user_id\` STRING,
  \`event_type\` STRING,
  \`event_time\` TIMESTAMP(3),
  \`payload\` STRING,
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'events',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : validated
-- type        : kafka
-- topic       : validated
-- format      : json
-- ====================================================================

CREATE TABLE \`validated\` WITH (
  'connector' = 'kafka',
  'topic' = 'validated',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : rejected
-- type        : kafka
-- topic       : rejected
-- format      : json
-- ====================================================================

CREATE TABLE \`rejected\` WITH (
  'connector' = 'kafka',
  'topic' = 'rejected',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : events
-- output      : validated
-- ====================================================================

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : events
-- output      : rejected
-- ====================================================================

EXECUTE STATEMENT SET BEGIN
INSERT INTO \`validated\`
SELECT * FROM \`events\`
WHERE \`event_id\` IS NOT NULL
    AND \`user_id\` IS NOT NULL;
INSERT INTO \`rejected\`
SELECT *,
    CASE
      WHEN \`event_id\` IS NULL THEN 'notNull:event_id'
      WHEN \`user_id\` IS NULL THEN 'notNull:user_id'
    END AS \`_validation_error\`,
    CURRENT_TIMESTAMP AS \`_validated_at\`
FROM \`events\`
WHERE NOT (
    \`event_id\` IS NOT NULL
    AND \`user_id\` IS NOT NULL
);
END;
"
`;

exports[`View produces CREATE VIEW > generates CREATE VIEW from upstream Map + Source 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : view-pipeline
-- ====================================================================

SET 'pipeline.name' = 'view-pipeline';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : orders
-- type        : kafka
-- topic       : orders
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`orders\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : high_value
-- type        : kafka
-- topic       : high-value
-- format      : json
-- ====================================================================

CREATE TABLE \`high_value\` WITH (
  'connector' = 'kafka',
  'topic' = 'high-value',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : all_orders
-- type        : kafka
-- topic       : all-orders
-- format      : json
-- ====================================================================

CREATE TABLE \`all_orders\` WITH (
  'connector' = 'kafka',
  'topic' = 'all-orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- VIEW
-- --------------------------------------------------------------------
-- name        : enriched_orders
-- ====================================================================

CREATE VIEW \`enriched_orders\` AS
SELECT \`order_id\` AS \`order_id\`, amount * quantity AS \`total\` FROM \`orders\`;

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- step        : Filter_4
-- type        : Filter
-- input       : enriched_orders
-- output      : high_value
-- rule        : total > 1000
-- ====================================================================

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : enriched_orders
-- output      : all_orders
-- ====================================================================

EXECUTE STATEMENT SET BEGIN
INSERT INTO \`high_value\`
SELECT * FROM (
SELECT * FROM \`enriched_orders\`
) WHERE total > 1000;
INSERT INTO \`all_orders\`
SELECT * FROM \`enriched_orders\`;
END;
"
`;
