  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : other
-- type        : kafka
-- topic       : other
-- format      : json
-- ====================================================================

CREATE TABLE \`other\` WITH (
  'connector' = 'kafka',
  'topic' = 'other',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : logs
-- output      : errors
-- ====================================================================

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : logs
-- output      : warnings
-- ====================================================================

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : logs
-- output      : other
-- ====================================================================

EXECUTE STATEMENT SET BEGIN
INSERT INTO \`errors\`
SELECT * FROM \`logs\`
WHERE \`level\` = 'ERROR';
INSERT INTO \`warnings\`
SELECT * FROM \`logs\`
WHERE \`level\` = 'WARN';
INSERT INTO \`other\`
SELECT * FROM \`logs\`;
END;
"
`;

exports[`Route produces correct multi-branch SQL > generates STATEMENT SET with branch conditions and transforms (JSX forward-reading) 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : inventory-analytics
-- ====================================================================

SET 'pipeline.name' = 'inventory-analytics';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : cdc_inventory_products
-- type        : kafka
-- topic       : cdc.inventory.products
-- format      : debezium-json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- group-id    : inventory-analytics
-- ====================================================================

CREATE TABLE \`cdc_inventory_products\` (
  \`id\` INT,
  \`name\` STRING,
  \`category\` STRING,
  \`price\` DOUBLE,
  \`quantity\` INT
) WITH (
  'connector' = 'kafka',
  'topic' = 'cdc.inventory.products',
  'format' = 'debezium-json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset',
  'properties.group.id' = 'inventory-analytics'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : low_stock_alerts
-- type        : kafka
-- topic       : low-stock-alerts
-- format      : json
-- bootstrap   : kafka:9092
-- ====================================================================

CREATE TABLE \`low_stock_alerts\` (
  \`id\` INT,
  \`name\` STRING,
  \`category\` STRING,
  \`price\` DOUBLE,
  \`quantity\` INT
) WITH (
  'connector' = 'kafka',
  'topic' = 'low-stock-alerts',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : category_stats
-- type        : kafka
-- topic       : category-stats
-- format      : json
-- bootstrap   : kafka:9092
-- ====================================================================

CREATE TABLE \`category_stats\` (
  \`category\` STRING,
  \`total_items\` BIGINT,
  \`avg_price\` DOUBLE,
  \`product_count\` BIGINT,
  PRIMARY KEY (\`category\`) NOT ENFORCED
) WITH (
  'connector' = 'upsert-kafka',
  'topic' = 'category-stats',
  'key.format' = 'json',
  'value.format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : cdc_inventory_products
-- output      : low_stock_alerts
-- ====================================================================

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- step        : Aggregate_4
-- type        : Aggregate
-- input       : cdc_inventory_products
-- output      : category_stats
-- group-by    : category
-- ====================================================================

EXECUTE STATEMENT SET BEGIN
INSERT INTO \`low_stock_alerts\`
SELECT * FROM \`cdc_inventory_products\`
WHERE \`quantity\` >= 0 AND \`quantity\` < 10;
INSERT INTO \`category_stats\`
SELECT \`category\`, SUM(\`quantity\`) AS \`total_items\`, AVG(\`price\`) AS \`avg_price\`, COUNT(*) AS \`product_count\` FROM \`cdc_inventory_products\` GROUP BY \`category\`;
END;
"
`;

exports[`SideOutput produces STATEMENT SET with main + side INSERTs > generates WHERE NOT for main path and WHERE for side path with metadata 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : side-output-pipeline
-- ====================================================================

SET 'pipeline.name' = 'side-output-pipeline';

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : orders
-- type        : kafka
-- topic       : orders
-- format      : json
-- bootstrap   : kafka:9092
-- startup     : earliest-offset
-- ====================================================================

CREATE TABLE \`orders\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`event_time\` TIMESTAMP(3),
  WATERMARK FOR \`event_time\` AS \`event_time\` - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : processed_orders
-- type        : kafka
-- topic       : processed-orders
-- format      : json
-- ====================================================================

CREATE TABLE \`processed_orders\` WITH (
  'connector' = 'kafka',
  'topic' = 'processed-orders',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : order_errors
-- type        : kafka
-- topic       : order-errors
-- format      : json
-- ====================================================================

CREATE TABLE \`order_errors\` WITH (
  'connector' = 'kafka',
  'topic' = 'order-errors',
  'format' = 'json',
  'properties.bootstrap.servers' = 'kafka:9092'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : orders
-- output      : processed_orders
-- ====================================================================

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : orders
-- output      : order_errors
-- ====================================================================

EXECUTE STATEMENT SET BEGIN
INSERT INTO \`processed_orders\`
SELECT * FROM \`orders\` WHERE NOT (amount < 0 OR user_id IS NULL);
INSERT INTO \`order_errors\`
SELECT *, CURRENT_TIMESTAMP AS \`_side_ts\`, 'invalid-order' AS \`_side_tag\` FROM \`orders\` WHERE (amount < 0 OR user_id IS NULL);
END;
"
`;

exports[`SideOutput produces STATEMENT SET with main + side INSERTs > generates side output without tag 1`] = `
