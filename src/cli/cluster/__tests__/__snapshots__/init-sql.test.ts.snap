exports[`generateInitSql > generates per-domain Kafka catalog with append-only table 1`] = `
"CREATE CATALOG \`ecom\` WITH ('type' = 'generic_in_memory');

USE CATALOG \`ecom\`;

CREATE TABLE IF NOT EXISTS \`orders\` (
  \`orderId\` STRING,
  \`amount\` DOUBLE,
  \`orderTime\` TIMESTAMP(3),
  WATERMARK FOR \`orderTime\` AS orderTime - INTERVAL '5' SECOND
) WITH (
  'connector' = 'kafka',
  'topic' = 'ecom.orders',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset',
  'format' = 'json'
);

USE CATALOG \`default_catalog\`;"
`;
