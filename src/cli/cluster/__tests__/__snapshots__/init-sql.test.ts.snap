// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`generateInitSql > generates DataGen seeding for Kafka tables 1`] = `
"CREATE TEMPORARY TABLE \`_datagen_ecom_orders\` (
  \`orderId\` STRING,
  \`amount\` DOUBLE
) WITH (
  'connector' = 'datagen',
  'rows-per-second' = '10'
);

INSERT INTO \`ecom\`.\`default\`.\`orders\` SELECT * FROM \`_datagen_ecom_orders\`;"
`;

exports[`generateInitSql > generates JDBC catalog SQL from config 1`] = `
"CREATE CATALOG \`my_db\` WITH (
  'type' = 'jdbc',
  'base-url' = 'jdbc:postgresql://myhost:5432/',
  'default-database' = 'mydb',
  'username' = 'admin',
  'password' = 'secret'
);"
`;

exports[`generateInitSql > generates Kafka table with debezium-json format and primary key 1`] = `
"CREATE CATALOG \`banking\` WITH ('type' = 'generic_in_memory');

USE CATALOG \`banking\`;

CREATE TABLE IF NOT EXISTS \`accounts\` (
  \`accountId\` STRING,
  \`name\` STRING,
  \`balance\` DOUBLE,
  PRIMARY KEY (\`accountId\`) NOT ENFORCED
) WITH (
  'connector' = 'kafka',
  'topic' = 'bank.accounts',
  'properties.bootstrap.servers' = 'kafka:9092',
  'scan.startup.mode' = 'earliest-offset',
  'format' = 'debezium-json'
);

USE CATALOG \`default_catalog\`;"
`;

