{
  "annotations": { "list": [] },
  "description": "FlinkReactor — pg-fluss-paimon pipeline observability. Per-job throughput, restarts, and checkpoint timings for the `ingest` (Postgres CDC → Fluss) and `serve` (Fluss → Paimon) jobs. Themed to match the Console.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Job Uptime",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "flink_jobmanager_job_uptime{job_name=~\"$job_name\"} / 1000",
          "refId": "A",
          "legendFormat": "{{job_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#a9b665" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "#a9b665", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Restarts",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "flink_jobmanager_job_numRestarts{job_name=~\"$job_name\"}",
          "refId": "A",
          "legendFormat": "{{job_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#a9b665", "value": null },
              { "color": "#d8a657", "value": 1 },
              { "color": "#ea6962", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Last Checkpoint Duration",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "flink_jobmanager_job_lastCheckpointDuration{job_name=~\"$job_name\"}",
          "refId": "A",
          "legendFormat": "{{job_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#7daea3", "value": null },
              { "color": "#d8a657", "value": 5000 },
              { "color": "#ea6962", "value": 30000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Records In / sec",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (job_name) (flink_taskmanager_job_task_operator_numRecordsInPerSecond{job_name=~\"$job_name\"})",
          "refId": "A",
          "legendFormat": "{{job_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "rps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ingest" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#a9b665" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "serve" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#7daea3" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Records Out / sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (job_name) (flink_taskmanager_job_task_operator_numRecordsOutPerSecond{job_name=~\"$job_name\"})",
          "refId": "A",
          "legendFormat": "{{job_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "rps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ingest" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#e78a4e" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "serve" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#c28fd6" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Checkpoint Duration",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "flink_jobmanager_job_lastCheckpointDuration{job_name=~\"$job_name\"}",
          "refId": "A",
          "legendFormat": "{{job_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ingest" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#a9b665" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "serve" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#7daea3" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Failed vs Completed Checkpoints",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "flink_jobmanager_job_numberOfCompletedCheckpoints{job_name=~\"$job_name\"}",
          "refId": "A",
          "legendFormat": "{{job_name}} completed"
        },
        {
          "expr": "flink_jobmanager_job_numberOfFailedCheckpoints{job_name=~\"$job_name\"}",
          "refId": "B",
          "legendFormat": "{{job_name}} failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*failed" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#ea6962" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["flink-reactor", "pg-fluss-paimon"],
