    {
      "id": 5,
      "type": "timeseries",
      "title": "JobManager Heap Usage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "flink_jobmanager_Status_JVM_Memory_Heap_Used",
          "refId": "A",
          "legendFormat": "Used"
        },
        {
          "expr": "flink_jobmanager_Status_JVM_Memory_Heap_Max",
          "refId": "B",
          "legendFormat": "Max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Used" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#a9b665" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Max" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#7c7269" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "TaskManager Heap Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "flink_taskmanager_Status_JVM_Memory_Heap_Used",
          "refId": "A",
          "legendFormat": "{{tm_id}} used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Records / sec (cluster total)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(flink_taskmanager_job_task_operator_numRecordsInPerSecond)",
          "refId": "A",
          "legendFormat": "in/s"
        },
        {
          "expr": "sum(flink_taskmanager_job_task_operator_numRecordsOutPerSecond)",
          "refId": "B",
          "legendFormat": "out/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "rps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "in/s" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#a9b665" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "out/s" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#e78a4e" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Checkpoints",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(flink_jobmanager_job_numberOfCompletedCheckpoints)",
          "refId": "A",
          "legendFormat": "Completed"
        },
        {
          "expr": "sum(flink_jobmanager_job_numberOfFailedCheckpoints)",
          "refId": "B",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Completed" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#7daea3" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#ea6962" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ],
