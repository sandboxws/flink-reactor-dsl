{
  "annotations": { "list": [] },
  "description": "FlinkReactor — Flink cluster overview. JobManager + TaskManagers + jobs + checkpoints. Themed to match the Console (Gruvppuccin).",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
