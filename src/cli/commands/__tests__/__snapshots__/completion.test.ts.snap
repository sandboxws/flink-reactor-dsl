// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`completion zsh > matches snapshot 1`] = `
"#compdef flink-reactor

# ── Auto-generated by: flink-reactor completion zsh ─────────────
# Install:
#   flink-reactor completion zsh > ~/.zsh/completions/_flink-reactor
#   eval "$(flink-reactor completion zsh)"

_flink_reactor() {
  local -a commands
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \\
    '(-V --version)'{-V,--version}'[output the version number]' \\
    '--verbose[Show full error traces for unexpected errors]' \\
    '1:command:->command' \\
    '*::args:->args'

  case $state in
    command)
      commands=(
        'new:Create a new FlinkReactor project'
        'doctor:Check your development environment'
        'install:Install tools for FlinkReactor development'
        'generate:Generate a new component'
        'g:Generate a new component'
        'synth:Synthesize pipelines to Flink SQL and CRDs'
        'validate:Validate pipeline definitions and configuration'
        'graph:Visualize pipeline DAG'
        'dev:Start development mode with file watching'
        'deploy:Deploy pipelines to the runtime for the current environment'
        'up:Start the runtime for the current environment (docker, minikube, or homebrew)'
        'down:Stop the runtime for the current environment (docker, minikube, or homebrew)'
        'cluster:Docker-runtime shortcut (alias of \`fr up --runtime=docker\`). Provides Docker-specific extras\\: seed, submit, status.'
        'schema:Display input and output schemas of a pipeline'
        'sim:Minikube-runtime shortcut (alias of \`fr up --runtime=minikube\`). Provides K8s-specific extras\\: status.'
        'upgrade:Upgrade FlinkReactor packages to their latest versions'
        'stop:Stop pipelines by suspending their FlinkDeployments (triggers savepoint)'
        'resume:Resume suspended pipelines (restores from last savepoint)'
        'savepoint:Trigger a savepoint for a running pipeline without stopping it'
        'status:Show the status of all pipelines in the cluster'
        'completion:Generate shell completion script'
      )
      _describe 'command' commands
      ;;
    args)
      case $line[1] in
        new)
          _flink_reactor_new
          ;;
        doctor)
          _flink_reactor_doctor
          ;;
        install)
          _flink_reactor_install
          ;;
        generate|g)
          _flink_reactor_generate
          ;;
        synth)
          _flink_reactor_synth
          ;;
        validate)
          _flink_reactor_validate
          ;;
        graph)
          _flink_reactor_graph
          ;;
        dev)
          _flink_reactor_dev
          ;;
        deploy)
          _flink_reactor_deploy
          ;;
        up)
          _flink_reactor_up
          ;;
        down)
          _flink_reactor_down
          ;;
        cluster)
          _flink_reactor_cluster
          ;;
        schema)
          _flink_reactor_schema
          ;;
        sim)
          _flink_reactor_sim
          ;;
        upgrade)
          _flink_reactor_upgrade
          ;;
        stop)
          _flink_reactor_stop
          ;;
        resume)
          _flink_reactor_resume
          ;;
        savepoint)
          _flink_reactor_savepoint
          ;;
        status)
          _flink_reactor_status
          ;;
        completion)
          _flink_reactor_completion
          ;;
      esac
      ;;
  esac
}

_flink_reactor_new() {
  _arguments \\
    '(-t --template)'{-t,--template}'[Project template]: :(starter minimal cdc-lakehouse realtime-analytics monorepo ecommerce ride-sharing grocery-delivery banking iot-factory lakehouse-ingestion lakehouse-analytics stock-basics stock-temporal-topn)' \\
    '--pm[Package manager]: :(pnpm npm yarn)' \\
    '--flink-version[Flink version]: :(1.20 2.0 2.1 2.2)' \\
    '--registry[npm registry]: :(npm verdaccio)' \\
    '(-y --yes)'{-y,--yes}'[Use defaults, skip prompts]' \\
    '--no-git[Skip git initialization]' \\
    '--no-install[Skip dependency installation]' \\
    '1:Name of the new project: '
}

_flink_reactor_doctor() {
  _message 'no more arguments'
}

_flink_reactor_install() {
  local -a subcommands
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \\
    '1:subcommand:->subcommand' \\
    '*::args:->args'

  case $state in
    subcommand)
      subcommands=(
        'flink:Install Apache Flink locally'
      )
      _describe 'subcommand' subcommands
      ;;
    args)
      case $line[1] in
        flink)
          _flink_reactor_install_flink
          ;;
      esac
      ;;
  esac
}

_flink_reactor_install_flink() {
  _arguments \\
    '--method[Installation method]: :(docker homebrew binary)' \\
    '--flink-version[Flink version (default\\: 1.20)]: : '
}

_flink_reactor_generate() {
  local -a subcommands
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \\
    '1:subcommand:->subcommand' \\
    '*::args:->args'

  case $state in
    subcommand)
      subcommands=(
        'pipeline:Generate a new pipeline'
        'schema:Generate a new schema file'
        'env:Generate a new environment config'
        'pattern:Generate a new reusable pattern'
        'app:Generate a new app (monorepo only)'
        'package:Generate a new package (monorepo only)'
      )
      _describe 'subcommand' subcommands
      ;;
    args)
      case $line[1] in
        pipeline)
          _flink_reactor_generate_pipeline
          ;;
        schema)
          _flink_reactor_generate_schema
          ;;
        env)
          _flink_reactor_generate_env
          ;;
        pattern)
          _flink_reactor_generate_pattern
          ;;
        app)
          _flink_reactor_generate_app
          ;;
        package)
          _flink_reactor_generate_package
          ;;
      esac
      ;;
  esac
}

_flink_reactor_generate_pipeline() {
  _arguments \\
    '(-t --template)'{-t,--template}'[Pipeline template]: :(blank kafka jdbc)' \\
    '1:Pipeline name: '
}

_flink_reactor_generate_schema() {
  _arguments \\
    '1:Schema name: '
}

_flink_reactor_generate_env() {
  _arguments \\
    '1:Environment name: '
}

_flink_reactor_generate_pattern() {
  _arguments \\
    '1:Pattern name: '
}

_flink_reactor_generate_app() {
  _arguments \\
    '1:App name: '
}

_flink_reactor_generate_package() {
  _arguments \\
    '1:Package name: '
}

_flink_reactor_synth() {
  _arguments \\
    '(-p --pipeline)'{-p,--pipeline}'[Synthesize a specific pipeline]: : ' \\
    '(-f --file)'{-f,--file}'[Synthesize a specific .tsx file or directory (bypasses pipelines/ convention)]: :_files' \\
    '(-e --env)'{-e,--env}'[Environment name (loads env/<name>.ts)]: : ' \\
    '(-o --outdir)'{-o,--outdir}'[Output directory]: :_files -/' \\
    '--deep-validate[Submit EXPLAIN to a running Flink cluster for semantic validation]' \\
    '--console-url[Push tap manifests to reactor-console at this URL]: : '
}

_flink_reactor_validate() {
  _arguments \\
    '(-p --pipeline)'{-p,--pipeline}'[Validate a specific pipeline]: : ' \\
    '(-e --env)'{-e,--env}'[Environment name]: : ' \\
    '--deep-validate[Submit EXPLAIN to a running Flink cluster for semantic validation]'
}

_flink_reactor_graph() {
  _arguments \\
    '(-p --pipeline)'{-p,--pipeline}'[Graph a specific pipeline]: : ' \\
    '(-f --format)'{-f,--format}'[Output format]: :(ascii dot svg)' \\
    '--open[Open SVG in browser (with --format svg)]'
}

_flink_reactor_dev() {
  _arguments \\
    '(-p --pipeline)'{-p,--pipeline}'[Watch a specific pipeline]: : ' \\
    '(-e --env)'{-e,--env}'[Environment name (default\\: auto-select)]: : ' \\
    '--no-cluster[Skip starting local Flink cluster]' \\
    '--runtime[Override the env'\\''s runtime (docker | minikube | homebrew | kubernetes)]: : ' \\
    '--port[Flink dashboard port]: : ' \\
    '--console-url[Push tap manifests to reactor-console at this URL]: : '
}

_flink_reactor_deploy() {
  _arguments \\
    '(-p --pipeline)'{-p,--pipeline}'[Deploy a specific pipeline]: : ' \\
    '(-e --env)'{-e,--env}'[Environment name (default\\: auto-select)]: : ' \\
    '--dry-run[Synth only, print generated artifacts without applying]' \\
    '--runtime[Override the env'\\''s runtime (docker | minikube | homebrew | kubernetes)]: : ' \\
    '--context[kubectl context (overrides env config)]: : ' \\
    '--console-url[Push tap manifests to reactor-console at this URL]: : '
}

_flink_reactor_up() {
  _arguments \\
    '(-e --env)'{-e,--env}'[Environment name (default\\: auto-select)]: : ' \\
    '--runtime[Override the env'\\''s runtime (docker | minikube | homebrew | kubernetes)]: : ' \\
    '--port[Flink REST port]: : ' \\
    '--seed[Submit example pipelines after startup (docker only)]'
}

_flink_reactor_down() {
  _arguments \\
    '(-e --env)'{-e,--env}'[Environment name (default\\: auto-select)]: : ' \\
    '--runtime[Override the env'\\''s runtime (docker | minikube | homebrew | kubernetes)]: : ' \\
    '--volumes[Remove persistent volumes]' \\
    '--all[Full teardown (e.g. stop the minikube VM entirely)]'
}

_flink_reactor_cluster() {
  local -a subcommands
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \\
    '1:subcommand:->subcommand' \\
    '*::args:->args'

  case $state in
    subcommand)
      subcommands=(
        'up:Start local Flink cluster (JM + 2×TM + SQL Gateway + Kafka + PostgreSQL)'
        'down:Stop local Flink cluster'
        'seed:Submit example SQL pipelines and publish CDC data'
        'status:Show cluster health, running jobs, and resource utilization'
        'submit:Submit a single SQL file via SQL Gateway'
      )
      _describe 'subcommand' subcommands
      ;;
    args)
      case $line[1] in
        up)
          _flink_reactor_cluster_up
          ;;
        down)
          _flink_reactor_cluster_down
          ;;
        seed)
          _flink_reactor_cluster_seed
          ;;
        status)
          _flink_reactor_cluster_status
          ;;
        submit)
          _flink_reactor_cluster_submit
          ;;
      esac
      ;;
  esac
}

_flink_reactor_cluster_up() {
  _arguments \\
    '--port[Flink REST port]: : ' \\
    '--seed[Submit example pipelines after startup]' \\
    '--domain[Filter seed data by domain]: :(ecommerce iot all)' \\
    '--no-timescaledb[Use plain PostgreSQL instead of TimescaleDB]'
}

_flink_reactor_cluster_down() {
  _arguments \\
    '--volumes[Remove Docker volumes (checkpoint and state data)]'
}

_flink_reactor_cluster_seed() {
  _arguments \\
    '--only[Filter by category]: :(streaming batch cdc cdc-kafka)' \\
    '--domain[Filter by domain]: :(ecommerce iot all)'
}

_flink_reactor_cluster_status() {
  _arguments \\
    '--port[Flink REST port]: : '
}

_flink_reactor_cluster_submit() {
  _arguments \\
    '--port[SQL Gateway port]: : ' \\
    '1::_files -g "*.sql"'
}

_flink_reactor_schema() {
  _arguments \\
    '--json[Output as JSON]' \\
    '--live[For Pipeline Connector sources (e.g. PostgresCdcPipelineSource), connect to the live database and introspect column metadata]' \\
    '--pg-connection-string[Postgres connection string (overrides FR_PG_CONNECTION_STRING)]: : ' \\
    '1:Path to a .tsx pipeline file, or a pipeline name:_files -g "*.tsx"'
}

_flink_reactor_sim() {
  local -a subcommands
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \\
    '1:subcommand:->subcommand' \\
    '*::args:->args'

  case $state in
    subcommand)
      subcommands=(
        'up:Bootstrap minikube cluster and deploy simulation infrastructure'
        'down:Tear down simulation infrastructure'
        'status:Show simulation pod status and resource usage'
      )
      _describe 'subcommand' subcommands
      ;;
    args)
      case $line[1] in
        up)
          _flink_reactor_sim_up
          ;;
        down)
          _flink_reactor_sim_down
          ;;
        status)
          _flink_reactor_sim_status
          ;;
      esac
      ;;
  esac
}

_flink_reactor_sim_up() {
  _arguments \\
    '--cpus[CPU cores for minikube]: : ' \\
    '--memory[Memory in MB for minikube]: : ' \\
    '--disk[Disk size for minikube]: : ' \\
    '--k8s-version[Kubernetes version]: : ' \\
    '--namespace[Target namespace]: : ' \\
    '--no-operator[Skip Flink Operator installation]' \\
    '(-e --env)'{-e,--env}'[Environment name from flink-reactor.config.ts (reads sim.init)]: : ' \\
    '--no-init[Skip resource initialization even if config exists]'
}

_flink_reactor_sim_down() {
  _arguments \\
    '--volumes[Delete persistent volume claims (checkpoint and state data)]' \\
    '--all[Also stop minikube entirely]' \\
    '--namespace[Target namespace]: : '
}

_flink_reactor_sim_status() {
  _arguments \\
    '--namespace[Target namespace]: : '
}

_flink_reactor_upgrade() {
  _arguments \\
    '--dry-run[Show what would be upgraded without installing]' \\
    '1::Package to upgrade: '
}

_flink_reactor_stop() {
  _arguments \\
    '(-a --all)'{-a,--all}'[Stop all pipelines in the namespace]' \\
    '(-e --env)'{-e,--env}'[Environment name]: : ' \\
    '(-n --namespace)'{-n,--namespace}'[Kubernetes namespace]: : ' \\
    '--context[kubectl context]: : ' \\
    '1::: '
}

_flink_reactor_resume() {
  _arguments \\
    '(-a --all)'{-a,--all}'[Resume all suspended pipelines in the namespace]' \\
    '(-e --env)'{-e,--env}'[Environment name]: : ' \\
    '(-n --namespace)'{-n,--namespace}'[Kubernetes namespace]: : ' \\
    '--context[kubectl context]: : ' \\
    '1::: '
}

_flink_reactor_savepoint() {
  _arguments \\
    '(-e --env)'{-e,--env}'[Environment name]: : ' \\
    '(-n --namespace)'{-n,--namespace}'[Kubernetes namespace]: : ' \\
    '--context[kubectl context]: : ' \\
    '1:: '
}

_flink_reactor_status() {
  _arguments \\
    '(-e --env)'{-e,--env}'[Environment name]: : ' \\
    '(-n --namespace)'{-n,--namespace}'[Kubernetes namespace]: : ' \\
    '--context[kubectl context]: : '
}

_flink_reactor_completion() {
  _arguments \\
    '1:Shell type (zsh): '
}

_flink_reactor "$@""
`;
