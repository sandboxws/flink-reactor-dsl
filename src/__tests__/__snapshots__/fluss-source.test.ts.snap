exports[`FlussSource → IcebergSink (upsertEnabled) > synthesizes the retract→Iceberg-MoR pipeline cleanly 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : fluss-iceberg-mor
-- ====================================================================

SET 'pipeline.name' = 'fluss-iceberg-mor';

-- ====================================================================
-- CATALOG
-- --------------------------------------------------------------------
-- id          : FlussCatalog_0
-- type        : fluss
-- ====================================================================

CREATE CATALOG \`fluss_cat\` WITH (
  'type' = 'fluss',
  'bootstrap.servers' = 'fluss-coordinator:9123'
);

-- ====================================================================
-- CATALOG
-- --------------------------------------------------------------------
-- id          : IcebergCatalog_1
-- type        : iceberg
-- uri         : http://iceberg-rest:8181
-- ====================================================================

CREATE CATALOG \`iceberg_cat\` WITH (
  'type' = 'iceberg',
  'catalog-type' = 'rest',
  'uri' = 'http://iceberg-rest:8181'
);

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : shop_orders
-- type        : fluss
-- catalog     : fluss_cat
-- database    : shop
-- table       : orders
-- startup     : initial
-- table-type  : PrimaryKey (retract)
-- ====================================================================

CREATE DATABASE IF NOT EXISTS \`fluss_cat\`.\`shop\`;
CREATE TABLE IF NOT EXISTS \`fluss_cat\`.\`shop\`.\`orders\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`order_ts\` TIMESTAMP(3),
  PRIMARY KEY (\`order_id\`) NOT ENFORCED
);
CREATE TEMPORARY VIEW \`shop_orders\` AS SELECT * FROM \`fluss_cat\`.\`shop\`.\`orders\`;

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : IcebergSink_3
-- type        : iceberg
-- ====================================================================

CREATE DATABASE IF NOT EXISTS \`iceberg_cat\`.\`lakehouse\`;
CREATE TABLE IF NOT EXISTS \`iceberg_cat\`.\`lakehouse\`.\`orders_mor\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`order_ts\` TIMESTAMP(3),
  PRIMARY KEY (\`order_id\`) NOT ENFORCED
) WITH (
  'format-version' = '2',
  'write.upsert.enabled' = 'true',
  'equality-field-columns' = 'order_id'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : shop_orders
-- output      : iceberg_cat
-- ====================================================================

INSERT INTO \`iceberg_cat\`.\`lakehouse\`.\`orders_mor\`
SELECT * FROM \`shop_orders\`;
"
`;

