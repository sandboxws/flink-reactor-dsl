exports[`FlussSource startup-mode × table-type matrix > renders primary-key table read with scanStartupMode='earliest' 1`] = `
"-- ====================================================================
-- PIPELINE
-- --------------------------------------------------------------------
-- name        : fluss-pg-paimon
-- ====================================================================

SET 'pipeline.name' = 'fluss-pg-paimon';

-- ====================================================================
-- CATALOG
-- --------------------------------------------------------------------
-- id          : FlussCatalog_0
-- type        : fluss
-- ====================================================================

CREATE CATALOG \`fluss_cat\` WITH (
  'type' = 'fluss',
  'bootstrap.servers' = 'fluss-coordinator:9123'
);

-- ====================================================================
-- CATALOG
-- --------------------------------------------------------------------
-- id          : PaimonCatalog_2
-- type        : paimon
-- warehouse   : s3://bucket/lake
-- ====================================================================

CREATE CATALOG \`lake\` WITH (
  'type' = 'paimon',
  'warehouse' = 's3://bucket/lake'
);

-- ====================================================================
-- SOURCE TABLE
-- --------------------------------------------------------------------
-- id          : shop_orders
-- type        : fluss
-- catalog     : fluss_cat
-- database    : shop
-- table       : orders
-- startup     : earliest
-- table-type  : PrimaryKey (retract)
-- ====================================================================

CREATE DATABASE IF NOT EXISTS \`fluss_cat\`.\`shop\`;
CREATE TABLE IF NOT EXISTS \`fluss_cat\`.\`shop\`.\`orders\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`order_ts\` TIMESTAMP(3),
  PRIMARY KEY (\`order_id\`) NOT ENFORCED
);
CREATE TEMPORARY VIEW \`shop_orders\` AS SELECT * FROM \`fluss_cat\`.\`shop\`.\`orders\`;

-- ====================================================================
-- SINK TABLE
-- --------------------------------------------------------------------
-- id          : PaimonSink_3
-- type        : paimon
-- ====================================================================

CREATE DATABASE IF NOT EXISTS \`lake\`.\`warehouse\`;
CREATE TABLE IF NOT EXISTS \`lake\`.\`warehouse\`.\`orders_view\` (
  \`order_id\` BIGINT,
  \`user_id\` STRING,
  \`amount\` DECIMAL(10, 2),
  \`order_ts\` TIMESTAMP(3),
  PRIMARY KEY (\`order_id\`) NOT ENFORCED
) WITH (
  'merge-engine' = 'deduplicate'
);

-- ====================================================================
-- TRANSFORMATION
-- --------------------------------------------------------------------
-- input       : shop_orders
-- output      : lake
-- ====================================================================

INSERT INTO \`lake\`.\`warehouse\`.\`orders_view\`
SELECT * FROM \`shop_orders\`;
"
`;

