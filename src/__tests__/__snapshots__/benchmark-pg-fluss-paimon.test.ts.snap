exports[`pg-fluss-paimon-ingest (Pipeline-YAML branch) > synthesizes a stable artifact bundle for initial + latency 1`] = `
{
  "crd": {
    "apiVersion": "flink.apache.org/v1beta1",
    "kind": "FlinkDeployment",
    "metadata": {
      "name": "pg-fluss-paimon-ingest",
    },
    "spec": {
      "flinkConfiguration": {
        "execution.checkpointing.interval": "2000",
        "execution.checkpointing.mode": "EXACTLY_ONCE",
        "execution.runtime-mode": "STREAMING",
      },
      "flinkVersion": "v2_0",
      "image": "flink:2.0",
      "job": {
        "args": [
          "--pipeline",
          "/etc/flink-cdc/pipeline.yaml",
        ],
        "jarURI": "local:///opt/flink-cdc/lib/flink-cdc-cli.jar",
        "parallelism": 4,
      },
      "jobManager": {
        "replicas": 1,
        "resource": {
          "cpu": "1",
          "memory": "1024m",
        },
      },
      "podTemplate": {
        "spec": {
          "containers": [
            {
              "env": [
                {
                  "name": "PG_PRIMARY_PASSWORD",
                  "valueFrom": {
                    "secretKeyRef": {
                      "key": "password",
                      "name": "pg-primary-password",
                    },
                  },
                },
              ],
              "name": "flink-main-container",
              "volumeMounts": [
                {
                  "mountPath": "/etc/flink-cdc",
                  "name": "pipeline-yaml",
                  "readOnly": true,
                },
              ],
            },
          ],
          "volumes": [
            {
              "configMap": {
                "name": "pg-fluss-paimon-ingest-pipeline",
              },
              "name": "pipeline-yaml",
            },
          ],
        },
      },
      "taskManager": {
        "resource": {
          "cpu": "1",
          "memory": "1024m",
        },
      },
    },
  },
  "jars": [
    "org.apache.flink:flink-cdc-pipeline-connector-fluss:3.6.0",
    "org.apache.flink:flink-cdc-pipeline-connector-postgres:3.6.0",
  ],
  "pipelineYaml": "source:
  type: postgres
  hostname: pg-primary
  port: 5432
  username: flink_cdc
  password: \${env:PG_PRIMARY_PASSWORD}
  database-name: tpch
  schema-name: public
  table-name: public.orders,public.lineitem,public.customer
  decoding.plugin.name: pgoutput
  slot.name: fr_pg_fluss_paimon_ingest_slot
  publication.name: fr_pg_fluss_paimon_ingest_pub
  scan.startup.mode: initial
  scan.snapshot.enabled: true
  scan.incremental.snapshot.chunk.size: 100000
sink:
  type: fluss
  name: pg-fluss-paimon-ingest-fluss-sink
  bootstrap.servers: fluss-coordinator:9123
  table.properties.bucket.num: '8'
  table.properties.bucket.key: o_orderkey
  schema.evolution.behavior: lenient
pipeline:
  name: pg-fluss-paimon-ingest
  parallelism: 4
  schema.change.behavior: evolve
",
}
`;

